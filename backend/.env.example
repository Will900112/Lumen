# Copy to .env and fill in real values.

# Required — AI / RAG
OPENAI_API_KEY=sk-...
COHERE_API_KEY=...
PINECONE_API_KEY=...
LLAMA_CLOUD_API_KEY=llx-...   # only needed for the one-time ETL scripts

# Required — auth
SECRET_KEY=<64-char random hex, e.g. from: python -c "import secrets; print(secrets.token_hex(32))">
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Database (omit to fall back to local SQLite for development)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:6543/postgres

# URLs (defaults shown — override in production)
FRONTEND_URL=http://localhost:3000
OAUTH_CALLBACK_URL=http://localhost:8000/auth/google/callback
# CORS_ORIGINS=https://prod.app,https://preview.app
